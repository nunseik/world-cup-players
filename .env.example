# Supabase Cloud Postgres connection string.
# Project Settings -> Database -> Connection string (Direct connection or Session pooler).
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# Scraper tuning (optional; defaults shown)
SCRAPE_HEADLESS=true
SCRAPE_DELAY_SECONDS=3.0          # FBref/Sports-Ref ask for <= ~10 requests/min
SCRAPE_TIMEOUT_MS=30000
SCRAPE_USER_AGENT=                # empty -> let real Chrome use its own UA

# Anti-bot (FBref/Cloudflare). "chrome" uses your installed Google Chrome and
# best clears the challenge; set "" to use patchright's bundled browser instead.
SCRAPE_BROWSER_CHANNEL=chrome
SCRAPE_CHALLENGE_WAIT_MS=25000

# FBref/Cloudflare: attach to a real Chrome you launched (`world-cup browser`)
# instead of letting Playwright launch one (Turnstile rejects automated browsers).
# Set this to that Chrome's DevTools endpoint, or pass `scrape --cdp`.
SCRAPE_CDP_URL=
SCRAPE_USER_DATA_DIR=.cache/cdp-chrome

# --- API server (optional; defaults shown) -------------------------------------
# Reads use a connection pool. Optionally point reads at a read replica / pooler
# distinct from the scraper's write DSN; empty falls back to SUPABASE_DB_URL.
API_READ_ONLY_DB_URL=
# workers * API_POOL_MAX must stay under your Postgres connection ceiling.
API_POOL_MIN=2
API_POOL_MAX=10
# Per-minute request budgets by tier.
API_RATE_FREE=60
API_RATE_PREMIUM=600
# Lifetime (days) of a newly issued key.
API_KEY_TTL_DAYS=30
# Signups allowed per client IP per hour (abuse guard on the public endpoint).
API_SIGNUP_PER_HOUR=5
